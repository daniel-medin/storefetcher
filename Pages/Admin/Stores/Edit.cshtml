@page "{id:int}"
@model StoreFetcher.Pages.Admin.Stores.EditModel
@{
    ViewData["Title"] = "Edit store";
}

<div class="d-flex align-items-center justify-content-between gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">Edit store</h1>
        <p class="text-muted mb-0">Saved changes are stored as StoreFetcher corrections, not written over imported OSM facts.</p>
    </div>
    <a class="btn btn-outline-secondary" asp-page="/Admin/Stores/Index">Back</a>
</div>

<form method="post" class="edit-grid">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input asp-for="Input.Id" type="hidden" />

    <label>
        Name
        <input class="form-control" asp-for="Input.Name" />
        <span class="text-danger" asp-validation-for="Input.Name"></span>
    </label>

    <label>
        Brand
        <input class="form-control" asp-for="Input.Brand" />
    </label>

    <label>
        Street
        <input class="form-control" asp-for="Input.Street" />
    </label>

    <label>
        House number
        <input class="form-control" asp-for="Input.HouseNumber" />
    </label>

    <label>
        Postcode
        <input class="form-control" asp-for="Input.Postcode" />
    </label>

    <label>
        City
        <input class="form-control" asp-for="Input.City" />
    </label>

    <label>
        Latitude
        <input class="form-control" asp-for="Input.Latitude" />
    </label>

    <label>
        Longitude
        <input class="form-control" asp-for="Input.Longitude" />
    </label>

    <label>
        Website
        <input class="form-control" asp-for="Input.Website" />
    </label>

    <label>
        Phone
        <input class="form-control" asp-for="Input.Phone" />
    </label>

    <label>
        Opening hours
        <input class="form-control" asp-for="Input.OpeningHours" />
    </label>

    <label>
        Shop type
        <input class="form-control" asp-for="Input.Shop" />
    </label>

    <label class="edit-wide">
        Notes
        <textarea class="form-control" asp-for="Input.Notes" rows="4"></textarea>
    </label>

    <label class="form-check edit-wide">
        <input class="form-check-input" asp-for="Input.IsActive" />
        <span class="form-check-label">Active</span>
    </label>

    <div class="edit-actions">
        <button class="btn btn-primary" type="submit">Save</button>
        <a class="btn btn-outline-secondary" href="@Model.Input.OsmUrl" target="_blank" rel="noreferrer">Open OSM</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
